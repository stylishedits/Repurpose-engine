# ── Database ──────────────────────────────────────────────────
# Get free MongoDB at mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/repurpose-engine

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── AI APIs ───────────────────────────────────────────────────
# Get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get at platform.openai.com
OPENAI_API_KEY=sk-your-key-here

# ── PayPal ────────────────────────────────────────────────────
# Get at developer.paypal.com → Apps & Credentials → Live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://repurpose-engine.vercel.app
NODE_ENV=production
